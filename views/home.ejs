<%- include('partials/header'); -%>

<main class="home-landing">
  <section class="home-hero">

    <div class="home-hero__text">
      <p class="home-hero__eyebrow">— 💀 Movies Curated by yours truly 💀 —</p>
      <h1 class="home-hero__heading">Haunted Frames</h1>
      <div class="home-hero__rule" aria-hidden="true"></div>
      <p class="home-hero__body">
       Summon a mood to see the horror films that match. Create an account to save your favorites.
      </p>
      <div class="home-hero__actions">
        <% if (locals.user) { %>
          <a href="/profile" class="btn btn--primary">My Profile</a>
          <a href="/haunts" class="btn btn--outline">Summon A Mood</a>
        <% } else { %>
          <a href="/signup" class="btn btn--primary">Sign Up</a>
          <a href="/haunts" class="btn btn--outline">Summon A Mood</a>
          <a href="/login" class="btn btn--ghost">Log In</a>
        <% } %>
      </div>
    </div>

    <div class="home-hero__visual" aria-hidden="true">
      <img src="/hero-artwork.jpg" alt="" class="home-hero__img" />
      <div class="home-hero__vignette"></div>
    </div>

  </section>
</main>

<%- include('partials/footer'); -%>
