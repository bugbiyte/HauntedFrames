<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Haunted Frames</title>
  <link rel="stylesheet" href="/styles.css" />
</head>

<body class="theme-dark">
  <nav class="horror-nav" aria-label="Primary">
    <a class="horror-nav__brand" href="/">
      <span class="horror-nav__sigil" aria-hidden="true">📽︎</span>
      <span class="horror-nav__title">Haunted Frames</span>
    </a>
    <ul class="horror-nav__links">
      <li><a href="/" class="horror-nav__link">Home</a></li>
      <% if (locals.user) { %>
        <li><a href="/profile" class="horror-nav__link">My Profile</a></li>
        <li><a href="/logout" class="horror-nav__link horror-nav__link--cta">Log Out</a></li>
      <% } else { %>
        <li><a href="/signup" class="horror-nav__link">Sign Up</a></li>
        <li><a href="/login" class="horror-nav__link horror-nav__link--cta">Login</a></li>
      <% } %>
    </ul>
  </nav>
